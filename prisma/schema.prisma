// ─── 电子签名 ─────────────────────────────────────────────────────────────────

enum SignatureStatus {
  PENDING           // 签名请求尚未创建
  AWAITING_ATTORNEY // 等待律师签名
  AWAITING_CLIENT   // 律师已签，等待客户
  COMPLETED         // 双方均已签
  VOIDED            // 已作废
}

model EngagementSignature {
  id             String   @id @default(cuid())
  engagementId   String   @unique
  engagement     EngagementConfirmation @relation("EngagementSignatureRel", fields: [engagementId], references: [id], onDelete: Cascade)

  // Docuseal 签名请求 IDs
  submissionId        String?  @db.VarChar(100)  // Docuseal submission ID
  docusealTemplateId  String?  @db.VarChar(100)  // 每次动态生成的 template ID

  status  SignatureStatus @default(PENDING)

  // 律师签名
  attorneySubmitterId String?  @db.VarChar(100)
  attorneyEmbedToken  String?  @db.Text  // Docuseal embed token（JWT）
  attorneySignedAt    DateTime?

  // 客户签名
  clientSubmitterId   String?  @db.VarChar(100)
  clientEmbedToken    String?  @db.Text
  clientSignedAt      DateTime?

