// ─── USCIS 案件追踪器 ─────────────────────────────────────────────────────────

/// USCIS 案件状态分类
enum USCISStatusCategory {
  PENDING   // 正常处理中
  ACTION    // 需要行动（面谈通知、指纹预约等）
  ALERT     // 需立即关注（RFE、拒签等）
  APPROVED  // 已批准
  COMPLETE  // 已完成（绿卡/证件已寄送）
}

/// 用户追踪的 USCIS 案件
model USCISTrackedCase {
  id              String              @id @default(cuid())

  // 所有者（可匿名）
  userId          String?             @db.Uuid
  user            User?               @relation("USCISTrackedCases", fields: [userId], references: [id], onDelete: Cascade)

  receiptNumber   String              // 收据号，如 LIN2401234567
  formType        String?             @db.VarChar(20)   // 用户填写，如 "I-485"
  nickname        String?             @db.VarChar(80)   // 用户自定义名称，如 "我的绿卡"

  // 最新状态（从 USCIS 抓取）
  lastStatus      String?             @db.VarChar(200)  // 状态标题
  lastStatusBody  String?             @db.Text          // 状态详情
  statusCategory  USCISStatusCategory @default(PENDING)
  lastCheckedAt   DateTime?

  // 状态历史（JSON 数组：[{ status, statusBody, category, checkedAt }]）
  statusHistory   Json                @default("[]")

  // 通知设置
  notifyOnChange  Boolean             @default(true)
  alertEmail      String?             @db.VarChar(200)  // 匿名用户邮件通知

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([userId, receiptNumber])
  @@index([userId])
  @@index([receiptNumber])
  @@index([statusCategory, lastCheckedAt])
}

// ─── 法律援助 / 低价服务包 ─────────────────────────────────────────────────────

/// 律师发布的固定价格服务包（免费/公益/低价/滑动收费）
model ServicePackage {
  id                String        @id @default(cuid())
  attorneyProfileId String

  // 服务基本信息
  title             String        @db.VarChar(120)   // 服务包名称（中文）
  titleEn           String?       @db.VarChar(120)   // 英文名称
  category          LegalCategory                    // 所属法律领域
  stateCode         String?       @db.Char(2)        // 服务州（null = 全国）
  description       String        @db.Text           // 服务描述
  deliverables      String        @db.Text           // 包含内容（markdown list）

  // 定价
  packageType       ServicePackageType @default(FIXED_PRICE)
  price             Decimal?      @db.Decimal(10, 2) // null = 免费/待协商
  priceLabel        String?       @db.VarChar(60)    // 展示文字："免费" / "¥99起" / "按收入定价"
  currency          String        @default("USD")    @db.VarChar(3)

  // 资格限制（法律援助用）
  incomeCapAnnual   Decimal?      @db.Decimal(12, 2) // 申请者年收入上限（null = 无限制）
  eligibilityCriteria String?     @db.Text           // 资格说明（如 "仅限低收入华人家庭"）

  // 服务细节
  estimatedDays     Int?                             // 预计完成天数
  maxCasesPerMonth  Int?                             // 每月可接收数量限制（防止过载）
  sessionCount      Int?                             // 包含咨询次数（如 "3次30分钟咨询"）
  sessionMinutes    Int?                             // 每次咨询时长（分钟）

  // 状态
  isActive          Boolean       @default(true)
  sortOrder         Int           @default(0)
  totalBooked       Int           @default(0)        // 累计预约次数（冷启动数据）

  // 关联
  attorney          AttorneyProfile @relation("AttorneyServicePackages", fields: [attorneyProfileId], references: [id], onDelete: Cascade)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([attorneyProfileId, isActive])
  @@index([category, isActive, packageType])
  @@index([stateCode, category, isActive])
  @@index([packageType, isActive, sortOrder])
}

enum ServicePackageType {
  PRO_BONO       // 完全免费（公益服务）
  SLIDING_SCALE  // 滑动收费（按收入比例）
  FIXED_PRICE    // 固定低价
  FREE_CONSULT   // 免费初次咨询（引流）
}

// ─── 律师转介绍网络（Referral Network）────────────────────────────────────────

enum ReferralStatus {
  PENDING      // 等待接收方确认
  ACCEPTED     // 已接受，案件进行中
  DECLINED     // 拒绝
  IN_PROGRESS  // 案件 Engagement 已建立，追踪中
  COMPLETED    // 完成，referral fee 已结清
  CANCELLED    // 转出方已撤销
  EXPIRED      // 邀请已过期（超过 expiresAt）
}

enum ReferralFeeMode {
  PERCENTAGE  // 按最终律师费比例（如 25%）
  FIXED       // 固定金额
  NONE        // 纯转介绍，不收 fee
}

enum ReferralFeeStatus {
  PENDING    // 等待案件完成后触发
  HELD       // 托管中（Engagement 完成后等待平台释放）
  RELEASED   // 已释放给转出方律师
  DISPUTED   // 争议中
  WAIVED     // 双方协商放弃
}

/// 律师间案件转介绍记录
model CaseReferral {
  id                   String          @id @default(cuid())

  // 参与双方（律师 profile ID）
  referrerAttorneyId   String          // 转出方
  receiverAttorneyId   String          // 接收方

  // 案件信息（脱敏描述，不含客户隐私）
  clientDescBrief      String          @db.Text          // 匿名案情描述
  legalCategory        LegalCategory                     // 法律领域
  stateCode            String?         @db.Char(2)       // 案件所在州
  urgencyNote          String?         @db.VarChar(200)  // 紧急程度说明

  // 关联平台资源（可选，均存 ID 不建 Prisma relation 避免耦合）
  sourceCaseId         String?         // 平台已有 Case ID
  linkedCaseId         String?         // 接收方在平台创建的 Case ID
  linkedEngagementId   String?         // 最终成交的 Engagement ID

  // Referral Fee 约定
  feeMode              ReferralFeeMode @default(NONE)
  feePercent           Decimal?        @db.Decimal(5, 2)   // 如 25.00 表示 25%
  feeAmount            Decimal?        @db.Decimal(10, 2)  // 固定金额
  feeCurrency          String          @default("USD")     @db.VarChar(3)
  feeNote              String?         @db.VarChar(500)    // 其他 fee 约定说明

  // 合规声明（符合 ABA Model Rule 1.5(e)）
  clientDisclosureAck  Boolean         @default(false)  // 已向客户书面披露转介绍安排
  conflictCheckDone    Boolean         @default(false)  // 已完成利益冲突检查
  barRuleAck           Boolean         @default(false)  // 确认遵守所在州律师协会规则

  // 状态
  status               ReferralStatus  @default(PENDING)
  declineReason        String?         @db.VarChar(500)
  notes                String?         @db.Text         // 转出方备注（接收方可见）
  receiverNote         String?         @db.Text         // 接收方回复备注

  // 时间戳
  acceptedAt           DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  expiresAt            DateTime?       // 邀请有效截止时间（null = 无限期）

  // 关联
  referrerAttorney     AttorneyProfile @relation("ReferralOutgoing", fields: [referrerAttorneyId], references: [id], onDelete: Cascade)
  receiverAttorney     AttorneyProfile @relation("ReferralIncoming", fields: [receiverAttorneyId], references: [id], onDelete: Cascade)
  feeRecord            ReferralFeeRecord?

  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([referrerAttorneyId, status, createdAt])
  @@index([receiverAttorneyId, status, createdAt])
  @@index([status, createdAt])
  @@index([legalCategory, stateCode, status])
}

/// Referral Fee 托管记录
model ReferralFeeRecord {
  id               String            @id @default(cuid())
  referralId       String            @unique

  feeAmount        Decimal           @db.Decimal(10, 2)  // 最终确定的 fee 金额
  feeCurrency      String            @default("USD")     @db.VarChar(3)
  calculationNote  String?           @db.VarChar(500)    // 计算说明（如：基于律师费 $5000 × 25%）

  // 可选：关联现有 PaymentOrder 体系做托管
  paymentOrderId   String?           @db.VarChar(100)

  status           ReferralFeeStatus @default(PENDING)
  heldAt           DateTime?
  releasedAt       DateTime?
  releaseNote      String?
  disputedAt       DateTime?
  disputeNote      String?
  waivedAt         DateTime?

  referral         CaseReferral      @relation(fields: [referralId], references: [id], onDelete: Cascade)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
}

// ─── 修复 #8: 律师档案变更审计日志 ───────────────────────────────────────────

// AttorneyProfileAuditLog — 记录律师修改自己档案的每次变更
// 用途：
// 1. 法律举证：若律师虚假宣传后删改，平台有完整历史记录
// 2. 合规审计：管理员可追溯任意时间点的律师信息
// 3. 争议解决：客户投诉时提供变更前快照
model AttorneyProfileAuditLog {
  id              String   @id @default(cuid())
  attorneyId      String   // 对应 AttorneyProfile.id（不加外键，即使档案删除也保留日志）
  operatorUserId  String?  @db.Uuid  // 操作者（律师本人或管理员）
  operationType   String   @db.VarChar(30)  // "SELF_UPDATE" | "ADMIN_UPDATE" | "ADMIN_VERIFY"
  changedFields   String[] // 变更的字段名称列表（例如 ["bio", "firmName"]）
  beforeSnapshot  Json?    // 变更前快照（仅包含 changedFields 对应的旧值）
  afterSnapshot   Json?    // 变更后快照（仅包含 changedFields 对应的新值）
  ipAddress       String?  @db.VarChar(50)
  userAgent       String?  @db.VarChar(300)
  note            String?  // 可选备注（管理员操作时可附说明）

  createdAt       DateTime @default(now())

  @@index([attorneyId])
  @@index([operatorUserId])
  @@index([createdAt])
}
