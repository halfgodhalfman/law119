// Q&A Community — 免费法律问答社区
// ─────────────────────────────────────────────────────────────────────────────

enum QaQuestionStatus {
  PUBLISHED      // 正常公开显示
  PENDING        // 等待管理员审核
  HIDDEN         // 管理员隐藏
  DELETED        // 软删除
}

enum QaAnswerStatus {
  PUBLISHED      // 正常公开显示
  HIDDEN         // 管理员隐藏
  DELETED        // 软删除
}

enum QaVoteType {
  HELPFUL        // 有帮助
}

model QaQuestion {
  id                String           @id @default(cuid())
  slug              String           @unique @db.VarChar(200)  // SEO-friendly URL slug
  title             String           @db.VarChar(200)
  body              String           // 问题正文
  category          LegalCategory
  stateCode         String?          @db.Char(2)
  preferredLanguage Language         @default(MANDARIN)
  // 匿名发布信息
  authorName        String           @default("匿名用户") @db.VarChar(80)
  authorUserId      String?          @db.Uuid
  authorEmail       String?          @db.VarChar(200)  // 不公开，仅用于通知
  status            QaQuestionStatus @default(PUBLISHED)
  viewCount         Int              @default(0)
  answerCount       Int              @default(0)       // 冗余计数，加速列表查询
  acceptedAnswerId  String?          @db.VarChar(50)   // 最佳回答 ID
  adminNote         String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  author            User?            @relation("QaQuestionAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  answers           QaAnswer[]

  @@index([category, status, createdAt])
  @@index([stateCode, status, createdAt])
  @@index([status, createdAt])
  @@index([authorUserId, createdAt])
}

model QaAnswer {
  id                String          @id @default(cuid())
  questionId        String
  authorUserId      String          @db.Uuid
  attorneyProfileId String?
  body              String
  status            QaAnswerStatus  @default(PUBLISHED)
  voteCount         Int             @default(0)        // 冗余投票数
  isAccepted        Boolean         @default(false)
  adminNote         String?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  question          QaQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author            User            @relation("QaAnswerAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  attorney          AttorneyProfile? @relation("QaAnswerAttorney", fields: [attorneyProfileId], references: [id], onDelete: SetNull)
  votes             QaVote[]

  @@index([questionId, status, createdAt])
  @@index([authorUserId, createdAt])
  @@index([attorneyProfileId, createdAt])
  @@index([isAccepted, createdAt])
}

model QaVote {
  id          String     @id @default(cuid())
  answerId    String
  userId      String?    @db.Uuid
  visitorKey  String?    @db.VarChar(64)  // 匿名用户防重投
  voteType    QaVoteType @default(HELPFUL)
  createdAt   DateTime   @default(now())

  answer      QaAnswer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user        User?      @relation("QaVoteUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([answerId, userId])
  @@unique([answerId, visitorKey])
  @@index([answerId, createdAt])
}

