# ============================================================
# Law119 环境变量模板
# 使用方法：cp .env.example .env.local  然后填入真实值
# 真实密钥请向项目负责人索取（不存在 Git 仓库中）
# ============================================================

# ── Supabase 云端项目（团队共用开发/生产 DB）──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<SUPABASE_ANON_KEY>"
SUPABASE_SERVICE_ROLE_KEY="<SUPABASE_SERVICE_ROLE_KEY>"

# ── Prisma 数据库连接 ─────────────────────────────────────────────────────────
# 从 Supabase Dashboard → Connect → Connection String 获取
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-us-west-2.pooler.supabase.com:5432/postgres"

# ── 本地 Supabase（可选，单机开发，需先 npx supabase start）──────────────────
# NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"
# SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# ── Dev Auth（仅本地调试用）──────────────────────────────────────────────────
DEV_AUTH_ENABLED=true

# ── Email 服务（Resend）──────────────────────────────────────────────────────
# 从 https://resend.com/api-keys 获取
RESEND_API_KEY=<RESEND_API_KEY>
RESEND_FROM_EMAIL=noreply@law119.com

# ── 电子签名（Docuseal）──────────────────────────────────────────────────────
# 从 https://console.docuseal.com → API Keys 获取
DOCUSEAL_API_KEY=<DOCUSEAL_API_KEY>
DOCUSEAL_WEBHOOK_SECRET=<DOCUSEAL_WEBHOOK_SECRET>
DOCUSEAL_API_URL="https://api.docuseal.com"
NEXT_PUBLIC_DOCUSEAL_HOST="docuseal.com"

# ── Stripe Connect（支付合规 Layer 2）────────────────────────────────────────
# 从 https://dashboard.stripe.com → Developers → API Keys 获取
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<YOUR_PUBLISHABLE_KEY>
STRIPE_SECRET_KEY=sk_live_<YOUR_SECRET_KEY>
# 从 Stripe Dashboard → Webhooks → 签名密钥 获取
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_WEBHOOK_SECRET>
# 平台技术服务费率（默认 5%）
STRIPE_PLATFORM_FEE_RATE=0.05
